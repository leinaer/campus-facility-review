/* components/evaluation-card/evaluation-card.wxss */
.evaluation-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-sizing: border-box;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.evaluation-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  min-height: 88rpx;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
  border: 3rpx solid rgba(255, 255, 255, 0.8);
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.3rpx;
}

.evaluate-time {
  font-size: 24rpx;
  color: #999;
}

.rating-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cd 100%);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 193, 7, 0.15);
}

.stars {
  font-size: 28rpx;
}

.rating-value {
  font-size: 26rpx;
  color: #ff9500;
  font-weight: 700;
}

/* 评价内容 */
.card-content {
  margin-bottom: 24rpx;
  word-wrap: break-word;
  word-break: break-all;
}

.content-text {
  font-size: 30rpx;
  color: #2c2c2c;
  line-height: 1.7;
  letter-spacing: 0.3rpx;
}

/* 图片展示 */
.card-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.evaluation-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8eaed 100%);
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.evaluation-image:active {
  transform: scale(0.96);
}

/* 卡片底部 */
.card-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.mood-tag {
  font-size: 36rpx;
}

.tag-item {
  font-size: 24rpx;
  color: #667eea;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
  border: 1rpx solid rgba(102, 126, 234, 0.15);
}

/* 互动栏 */
.interaction-bar {
  display: flex;
  gap: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  margin-top: 24rpx;
}

.interaction-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  flex-shrink: 0;
  background: rgba(245, 247, 250, 0.5);
}

.interaction-item:active {
  background: rgba(102, 126, 234, 0.1);
  transform: scale(0.95);
}

.interaction-item.liked {
  background: rgba(255, 77, 79, 0.08);
}

.interaction-item.liked .count {
  color: #ff4d4f;
  font-weight: 600;
}

.icon {
  width: 44rpx !important;
  height: 44rpx !important;
}

.interaction-item.liked .icon {
  animation: likeAnimation 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.interaction-item.more-btn {
  margin-left: auto;
  background: transparent;
}

.more-icon {
  font-size: 32rpx;
  color: #999;
  font-weight: bold;
  padding: 4rpx;
}

.icon.active {
  filter: brightness(1.1);
}

.count.active {
  color: #ff4d4f;
}

.comment-icon {
  font-size: 36rpx;
  width: 36rpx !important;
  height: 36rpx !important;
}

@keyframes likeAnimation {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.35);
  }
  100% {
    transform: scale(1);
  }
}

.count {
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s ease;
  font-weight: 500;
}

/* 评论区域 */
.comment-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.comment-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.comment-user-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.comment-user {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
}

.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.reply-to {
  color: #667eea;
  font-weight: 600;
}

.comment-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.like-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #999;
  cursor: pointer;
}

.like-btn.liked {
  color: #ff4757;
}

.like-icon {
  font-size: 24rpx;
}

.like-count {
  font-size: 22rpx;
}

.reply-btn {
  font-size: 24rpx;
  color: #667eea;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(102, 126, 234, 0.1);
}

.replies-count {
  font-size: 22rpx;
  color: #999;
}

/* 楼中楼子评论 */
.sub-comments {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #e0e0e0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.sub-comment-item {
  padding: 16rpx;
  background: #ffffff;
  border-radius: 12rpx;
}

.sub-comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.sub-comment-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.sub-comment-user-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.sub-comment-user {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.sub-comment-time {
  font-size: 20rpx;
  color: #999;
}

.sub-comment-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.sub-comment-actions {
  display: flex;
}

/* 空评论提示 */
.empty-comment {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}