.page {
  background-color: #f5f6f8;
}

.container {
  padding: 0 0 160rpx 0;
}

/* 设施卡片 */
.facility-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
  color: #fff;
}

.facility-header {
  display: flex;
  gap: 24rpx;
}

.facility-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.facility-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.facility-name {
  font-size: 36rpx;
  font-weight: bold;
}

.facility-location {
  font-size: 24rpx;
  opacity: 0.9;
}

.facility-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 10rpx;
}

.stars {
  font-size: 28rpx;
}

.score {
  font-size: 32rpx;
  font-weight: bold;
}

.count {
  font-size: 22rpx;
  opacity: 0.8;
}

/* 表单区域 */
.form-section {
  background: #ffffff;
  margin: 20rpx 30rpx;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.required-mark {
  font-size: 22rpx;
  color: #ff4757;
  background: rgba(255, 71, 87, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.optional-mark {
  font-size: 22rpx;
  color: #999;
}

/* 评分 */
.rating-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.stars-wrapper {
  display: flex;
  gap: 16rpx;
}

.star {
  font-size: 64rpx;
  filter: grayscale(100%);
  opacity: 0.3;
  transition: all 0.3s;
}

.star.active {
  filter: grayscale(0%);
  opacity: 1;
  transform: scale(1.1);
}

.rating-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 600;
}

/* 心情网格 */
.mood-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 10rpx;
  border-radius: 16rpx;
  background: #f8f9fa;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.mood-item.active {
  background: rgba(102, 126, 234, 0.1);
  border-color: #667eea;
}

.mood-emoji {
  font-size: 56rpx;
}

.mood-name {
  font-size: 24rpx;
  color: #666;
}

.mood-item.active .mood-name {
  color: #667eea;
  font-weight: 600;
}

/* 内容输入 */
.char-counter {
  font-size: 24rpx;
  color: #999;
}

.textarea-wrapper {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
}

.content-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  background: transparent;
}

.content-textarea::placeholder {
  color: #999;
}

/* 图片网格 */
.image-grid {
  display: grid;
  gap: 16rpx;
}

.single {
  grid-template-columns: 1fr;
  max-width: 400rpx;
  margin: 0 auto;
}

.double {
  grid-template-columns: repeat(2, 1fr);
}

.triple {
  grid-template-columns: repeat(3, 1fr);
}

.multi {
  grid-template-columns: repeat(3, 1fr);
}

.image-item {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 16rpx;
  overflow: hidden;
}

.uploaded-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
}

.add-image-btn {
  width: 100%;
  padding-top: 100%;
  border: 2rpx dashed #ddd;
  border-radius: 16rpx;
  background: #fafafa;
  position: relative;
}

.add-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 64rpx;
  color: #999;
}

.add-text {
  position: absolute;
  top: calc(50% + 40rpx);
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  color: #999;
}

/* 标签 */
.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.selected-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.selected-tag.custom {
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.tag-delete {
  font-size: 28rpx;
  margin-left: 4rpx;
}

.tags-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 12rpx 24rpx;
  background: #f0f0f0;
  color: #666;
  border-radius: 24rpx;
  font-size: 26rpx;
  transition: all 0.3s;
}

.tag-item.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-weight: 600;
}

.tag-item.add-tag {
  border: 2rpx dashed #667eea;
  background: transparent;
  color: #667eea;
}

/* 底部 */
.bottom-space {
  height: 40rpx;
}

/* 提交按钮 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #e0e0e0;
  color: #999;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s;
}

.submit-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.submit-btn::after {
  border: none;
}
