.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #ffffff 100%);
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.25);
  position: relative;
  transition: all 0.3s;
}

.user-header {
  display: flex;
  gap: 30rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  flex: 1;
}

.level-tag {
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.4);
}

.level-num {
  font-size: 24rpx;
  font-weight: bold;
  color: #8b4513;
}

.level-name {
  font-size: 24rpx;
  color: #8b4513;
  font-weight: 600;
}

.user-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.role-tag, .level-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
}

.role-tag.user {
  background: rgba(255, 255, 255, 0.15);
}

.level-tag {
  background: rgba(255, 215, 0, 0.3);
  font-weight: 500;
}

.signature {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
}

.signature.empty {
  opacity: 0.6;
  font-style: italic;
  color: rgba(255, 255, 255, 0.8);
}

/* 数据统计 */
.stats-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 等级进度区域 */
.level-section {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 24rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.level-section.max {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.25) 0%, rgba(255, 237, 78, 0.25) 100%);
  border: 1rpx solid rgba(255, 215, 0, 0.4);
  text-align: center;
  padding: 20rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-label {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.progress-score {
  font-size: 28rpx;
  color: #ffd700;
  font-weight: bold;
}

.progress-bar {
  height: 16rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffd700 0%, #ffed4e 50%, #ffd700 100%);
  border-radius: 8rpx;
  transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(255, 215, 0, 0.5);
  position: relative;
}

.progress-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 100%);
  border-radius: 8rpx 8rpx 0 0;
}

.progress-tip {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  line-height: 1.5;
}

.max-text {
  font-size: 28rpx;
  color: #ffd700;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 积分明细 */
.score-breakdown {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: 30rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.score-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.score-weight {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-top: 4rpx;
}

.score-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 功能菜单 */
.my-section {
  margin: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.menu-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-badge {
  font-size: 22rpx;
  color: #fff;
  background: #667eea;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
  min-width: 32rpx;
  text-align: center;
}

.menu-badge.red {
  background: #ff4d4f;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 最近评价 */
.evaluation-section {
  margin: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.view-all {
  font-size: 24rpx;
  color: #667eea;
}

.evaluation-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.evaluation-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.evaluation-item:last-child {
  border-bottom: none;
}

.eval-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.content-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.eval-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rating {
  font-size: 24rpx;
  color: #ff9800;
}

.eval-time {
  font-size: 22rpx;
  color: #999;
}

.empty-tip {
  background: #fff;
  border-radius: 16rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 30rpx;
}

.empty-action-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  border: none;
}

/* 管理员入口 */
.admin-entry-section {
  margin: 20rpx;
}

.admin-entry-btn {
  width: 100%;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(245, 87, 108, 0.3);
}

.btn-icon {
  margin-right: 12rpx;
}

/* 退出登录 */
.logout-section {
  margin: 40rpx 20rpx 20rpx;
}

.logout-btn {
  width: 100%;
  background: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
}
