/* pages/my-evaluations/my-evaluations.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f6f8;
  padding-bottom: 20rpx;
}

/* 分类 Tab */
.tab-bar {
  display: flex;
  background-color: #fff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab-item.active {
  color: #ff2442;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: #ff2442;
  border-radius: 3rpx;
}

.tab-count {
  font-size: 22rpx;
  color: #999;
}

.tab-item.active .tab-count {
  color: #ff2442;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  background-color: #fff;
  padding: 0 20rpx;
  gap: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.sort-item {
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.sort-item.active {
  color: #ff2442;
  font-weight: 600;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #ff2442;
  border-radius: 2rpx;
}

/* 评价列表 */
.evaluation-list {
  padding: 20rpx;
}

.evaluation-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 设施信息 */
.facility-info {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.facility-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #f5f6f8;
}

.facility-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.facility-detail.no-cover {
  justify-content: center;
}

.facility-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.facility-location {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.rating-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.rating-badge {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.rating-badge.good {
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
}

.rating-badge.medium {
  background: linear-gradient(135deg, #ffa726 0%, #ffcc80 100%);
}

.rating-badge.bad {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
}

.rating-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.rating-label {
  font-size: 20rpx;
  color: #666;
}

.mood-icon {
  font-size: 36rpx;
}

/* 评价内容 */
.evaluation-content {
  margin-bottom: 16rpx;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* 评价图片 */
.image-grid {
  display: flex;
  gap: 12rpx;
  margin: 16rpx 0;
}

.image-grid.single-img .evaluation-image {
  width: 400rpx;
  height: 300rpx;
}

.image-grid.double-img .evaluation-image {
  width: calc(50% - 6rpx);
  height: 200rpx;
}

.image-grid.multi-img .evaluation-image {
  width: calc(33.33% - 8rpx);
  height: 180rpx;
}

.evaluation-image {
  border-radius: 12rpx;
  background-color: #f5f6f8;
}

/* 评价标签 */
.evaluation-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag-item {
  background-color: #f0f3ff;
  color: #667eea;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 操作栏 */
.action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-time {
  font-size: 24rpx;
  color: #999;
}

.action-buttons {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #ff4d4f;
  padding: 8rpx 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.go-evaluate-btn {
  padding: 20rpx 60rpx;
  background-color: #ff2442;
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  border: none;
}

.go-evaluate-btn::after {
  border: none;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 40rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}
