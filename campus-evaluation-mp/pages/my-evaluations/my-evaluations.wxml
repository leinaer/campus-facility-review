<!-- pages/my-evaluations/my-evaluations.wxml -->
<view class="container">
  <!-- 分类 Tab -->
  <view class="tab-bar">
    <view
      class="tab-item {{filterType === 'all' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-type="all"
    >
      <text>全部</text>
      <text class="tab-count">{{stats.all || 0}}</text>
    </view>
    <view
      class="tab-item {{filterType === 'good' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-type="good"
    >
      <text>好评</text>
      <text class="tab-count">{{stats.good || 0}}</text>
    </view>
    <view
      class="tab-item {{filterType === 'medium' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-type="medium"
    >
      <text>中评</text>
      <text class="tab-count">{{stats.medium || 0}}</text>
    </view>
    <view
      class="tab-item {{filterType === 'bad' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-type="bad"
    >
      <text>差评</text>
      <text class="tab-count">{{stats.bad || 0}}</text>
    </view>
  </view>

  <!-- 排序栏 -->
  <view class="sort-bar">
    <view class="sort-item {{sortBy === 'latest' ? 'active' : ''}}" bindtap="switchSort" data-sort="latest">
      <text>最新</text>
    </view>
    <view class="sort-item {{sortBy === 'highest' ? 'active' : ''}}" bindtap="switchSort" data-sort="highest">
      <text>最高分</text>
    </view>
    <view class="sort-item {{sortBy === 'lowest' ? 'active' : ''}}" bindtap="switchSort" data-sort="lowest">
      <text>最低分</text>
    </view>
  </view>

  <!-- 评价列表 -->
  <view class="evaluation-list" wx:if="{{filteredEvaluations.length > 0}}">
    <view
      class="evaluation-card"
      wx:for="{{filteredEvaluations}}"
      wx:key="evaluationId"
    >
      <!-- 设施信息 -->
      <view class="facility-info" bindtap="goToFacility" data-facility-id="{{item.facilityId}}">
        <!-- 只显示设施自己的封面图，不显示评价的图片 -->
        <image
          wx:if="{{item.facilityOwnCover}}"
          class="facility-cover"
          src="{{item.facilityOwnCover}}"
          mode="aspectFill"
          lazy-load
        />
        <view class="facility-detail {{item.facilityOwnCover ? '' : 'no-cover'}}">
          <text class="facility-name">{{item.facilityName}}</text>
          <text wx:if="{{item.facilityLocation}}" class="facility-location">{{item.facilityLocation}}</text>
          <view class="rating-row">
            <view class="rating-badge {{item.rating >= 4 ? 'good' : item.rating >= 3 ? 'medium' : 'bad'}}">
              <text class="rating-text">{{item.rating}}</text>
              <text class="rating-label">分</text>
            </view>
            <view wx:if="{{item.mood}}" class="mood-icon">{{item.mood === 'happy' ? '😊' : item.mood === 'excited' ? '' : item.mood === 'sad' ? '' : item.mood === 'angry' ? '' : ''}}</view>
          </view>
        </view>
      </view>

      <!-- 评价内容 -->
      <view wx:if="{{item.content}}" class="evaluation-content">
        <text class="content-text">{{item.content}}</text>
      </view>

      <!-- 评价图片（评价用户自己上传的图片） -->
      <view wx:if="{{item.evaluationImages && item.evaluationImages.length > 0}}" class="image-grid {{item.evaluationImages.length === 1 ? 'single-img' : item.evaluationImages.length === 2 ? 'double-img' : 'multi-img'}}">
        <image
          wx:for="{{item.evaluationImages}}"
          wx:key="index"
          class="evaluation-image"
          src="{{item}}"
          mode="aspectFill"
          lazy-load
        ></image>
      </view>

      <!-- 评价标签 -->
      <view wx:if="{{item.tags && item.tags.length > 0}}" class="evaluation-tags">
        <text class="tag-item" wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag">{{tag}}</text>
      </view>

      <!-- 操作栏 -->
      <view class="action-bar">
        <text class="action-time">{{item.createTime}}</text>
        <view class="action-buttons">
          <view class="action-btn delete" catchtap="deleteEvaluation" data-id="{{item.evaluationId}}">
            <text>删除</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredEvaluations.length === 0 && !loading}}">
    <text class="empty-icon"></text>
    <text class="empty-text">暂无{{filterType === 'all' ? '' : filterType === 'good' ? '好评' : filterType === 'medium' ? '中评' : '差评'}}评价</text>
    <button class="go-evaluate-btn" bindtap="goToDiscover">去评价</button>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
