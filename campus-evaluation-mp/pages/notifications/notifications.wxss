/* pages/notifications/notifications.wxss */
.notifications-page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.mark-all {
  font-size: 26rpx;
  color: #FF9800;
}

.content {
  flex: 1;
  padding: 20rpx;
}

.notification-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notification-item {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.notification-item.unread {
  background: rgba(255, 152, 0, 0.05);
  border-left: 4rpx solid #FF9800;
}

.notif-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.notif-content {
  flex: 1;
}

.notif-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.notif-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.notif-time {
  font-size: 22rpx;
  color: #999;
}

.notif-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.notif-actions {
  flex-shrink: 0;
}

.delete-btn {
  font-size: 32rpx;
  color: #ccc;
  padding: 8rpx;
}

.loading-more,
.no-more {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
