/* pages/publish/publish.wxss */
page {
  background-color: #f8f9fa;
}

.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.required-mark {
  color: #ff4d4f;
  font-size: 32rpx;
  margin-right: 8rpx;
  font-weight: bold;
}

.image-tip {
  font-size: 24rpx;
  font-weight: normal;
  color: #999;
}

/* 心情选择 */
.mood-grid {
  display: flex;
  justify-content: space-around;
  gap: 20rpx;
}

.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  background: #f5f7fa;
  transition: all 0.3s;
  flex: 1;
}

.mood-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.mood-emoji {
  font-size: 48rpx;
}

.mood-text {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.mood-item.active .mood-text {
  color: #fff;
}

/* 输入框样式 */
.input-wrapper,
.textarea-wrapper {
  position: relative;
}

.title-input,
.content-textarea {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.title-input {
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 24rpx;
  background: #fafafa;
}

.title-input:focus {
  border-color: #667eea;
  background: #fff;
}

.content-textarea {
  min-height: 240rpx;
  padding: 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  background: #fafafa;
}

.content-textarea:focus {
  border-color: #667eea;
  background: #fff;
}

.placeholder {
  color: #999;
  font-size: 28rpx;
}

.input-count,
.textarea-count {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  font-size: 24rpx;
  color: #ccc;
}

.input-count.has-text,
.textarea-count.has-text {
  color: #667eea;
}

/* 图片上传 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: calc((100% - 40rpx) / 3);
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image {
  width: 100%;
  height: 100%;
}

.image-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.image-item:active .image-mask {
  opacity: 1;
}

.delete-icon {
  font-size: 64rpx;
  color: #fff;
  font-weight: 300;
}

.upload-btn {
  width: calc((100% - 40rpx) / 3);
  height: 200rpx;
  border: 3rpx dashed #d0d0d0;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #fafafa;
}

.upload-plus {
  font-size: 64rpx;
  color: #999;
  font-weight: 300;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

/* 话题选择 */
.topic-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.topic-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border-radius: 36rpx;
  background: #f0f5ff;
  border: 2rpx solid #d9e5ff;
  transition: all 0.2s;
}

.topic-tag.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
}

.topic-tag-icon {
  font-size: 28rpx;
}

.topic-tag-text {
  font-size: 26rpx;
  color: #5a6abf;
  font-weight: 500;
}

.topic-tag.active .topic-tag-icon,
.topic-tag.active .topic-tag-text {
  color: #ffffff;
}

.add-tag {
  background: #fafafa;
  border: 2rpx dashed #d0d0d0;
}

.add-symbol {
  font-size: 28rpx;
  color: #999;
  font-weight: 300;
}

.add-tag text:last-child {
  font-size: 26rpx;
  color: #999;
}

/* 封面选择 */
.cover-list {
  display: flex;
  gap: 20rpx;
  overflow-x: auto;
  padding: 20rpx 0;
}

.cover-item {
  position: relative;
  flex-shrink: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
}

.cover-item.active {
  border-color: #667eea;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 发布按钮 */
.submit-section {
  padding: 40rpx 0 60rpx 0;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #999;
  background: #e8e8e8;
  border: none;
  transition: all 0.3s;
}

.submit-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.submit-btn[disabled] {
  opacity: 1;
}

.upload-progress {
  display: block;
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #667eea;
}

/* 标签样式 */
.tag-tip {
  font-size: 24rpx;
  font-weight: normal;
  color: #999;
}

.tag-group {
  margin-bottom: 24rpx;
}

.tag-group:last-child {
  margin-bottom: 0;
}

.tag-group-title {
  display: block;
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 14rpx 24rpx;
  border-radius: 32rpx;
  background: #f5f7fa;
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
  gap: 8rpx;
  transition: all 0.2s;
}

.tag-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.tag-icon {
  font-size: 28rpx;
}

.add-tag-btn {
  border: 2rpx dashed #d0d0d0;
  background: transparent;
}

.add-tag-btn text {
  color: #999;
}

.selected-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
  margin-top: 20rpx;
}

.selected-title {
  font-size: 26rpx;
  color: #666;
}

.selected-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 28rpx;
  background: #667eea;
  color: #fff;
  font-size: 24rpx;
}

.delete-tag {
  font-size: 32rpx;
  font-weight: 300;
  margin-left: 4rpx;
}

