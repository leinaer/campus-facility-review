/* pages/admin/evaluation-manage.wxss */
page {
  background-color: #f8f9fa;
}

.evaluation-manage-container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 头部 */
.header-bar {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.total-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  background-color: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 加载状态 */
.loading-state,
.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.loading-text,
.empty-text {
  font-size: 28rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

/* 评价列表 */
.evaluation-list {
  padding: 30rpx;
}

.evaluation-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 评价头部 */
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-info {
  flex: 1;
}

.facility-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.eval-type {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.type-EVALUATION {
  background-color: #e3f2fd;
  color: #2196f3;
}

.type-POST {
  background-color: #f3e5f5;
  color: #9c27b0;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-tag.status-1 {
  background-color: #e8f5e9;
  color: #4caf50;
}

.status-tag.status-0 {
  background-color: #ffebee;
  color: #f44336;
}

/* 评分 */
.rating-display {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.stars {
  font-size: 32rpx;
}

.rating-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff9800;
}

/* 评价内容 */
.item-content {
  margin-bottom: 20rpx;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 图片网格 */
.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.image-item {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #f8f9fa;
}

/* 标签 */
.tags-display {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag-item {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background-color: #f0f0f0;
  border-radius: 20rpx;
  color: #666;
}

/* 统计信息 */
.item-stats {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.item-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
}

.action-btn:active {
  opacity: 0.8;
}

.delete-btn {
  background-color: #ffebee;
  color: #f44336;
}
