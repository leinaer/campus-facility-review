page {
  background-color: #f8f9fa;
}

.statistics-container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header-bar {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding: 0 30rpx;
}

.overview-section {
  margin-top: 30rpx;
  margin-bottom: 30rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 0 30rpx;
}

.overview-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.overview-item.highlight {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.overview-item.highlight .overview-num,
.overview-item.highlight .overview-label {
  color: #fff;
}

.overview-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
  margin-bottom: 10rpx;
}

.overview-label {
  font-size: 22rpx;
  color: #999;
}

.chart-section {
  margin-bottom: 30rpx;
}

.chart-card {
  background: #fff;
  margin: 0 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.empty-hint {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}

.bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 300rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #e0e0e0;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
  justify-content: flex-end;
}

.bar-wrapper {
  width: 60rpx;
  height: 240rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  margin-bottom: 10rpx;
}

.bar-fill {
  width: 100%;
  min-height: 4rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: linear-gradient(to top, #667eea, #764ba2);
  transition: height 0.3s ease;
}

.bar-value {
  font-size: 24rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 8rpx;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
  transform: rotate(-45deg);
  white-space: nowrap;
}

.donut-chart-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.donut-chart {
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  position: relative;
}

.donut-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 180rpx;
  height: 180rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.donut-total {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.donut-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.legend-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 0 0 calc(50% - 10rpx);
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.legend-name {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.legend-value {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
}

.top-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.top-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.top-item:last-child {
  border-bottom: none;
}

.rank-badge {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  flex-shrink: 0;
}

.rank-badge.top3 {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.rank-badge.normal {
  background-color: #e0e0e0;
  color: #666;
}

.top-info {
  flex: 1;
}

.top-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.top-meta {
  font-size: 24rpx;
  color: #999;
}
