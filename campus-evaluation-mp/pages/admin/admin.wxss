/* pages/admin/admin.wxss */
.admin-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 用户信息头部 */
.user-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  color: white;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-info {
  margin-left: 30rpx;
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.role-badge {
  display: inline-block;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 统计数据 */
.statistics-section {
  background-color: white;
  margin: 30rpx;
  padding: 40rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 功能入口 */
.function-section {
  background-color: white;
  margin: 0 30rpx 30rpx;
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.function-item {
  background-color: #f8f9fa;
  padding: 40rpx;
  border-radius: 16rpx;
  text-align: center;
  transition: all 0.3s;
}

.function-item:active {
  background-color: #e9ecef;
  transform: scale(0.98);
}

.icon-box {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
}

.category-icon {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.facility-icon {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.evaluation-icon {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.statistics-icon {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.function-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 切换视角 */
.switch-view-section {
  margin: 0 30rpx 30rpx;
}

.switch-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  font-size: 30rpx;
  padding: 30rpx 0;
}

/* 退出登录 */
.logout-section {
  margin: 0 30rpx;
}

.logout-btn {
  background-color: white;
  color: #ff4757;
  border: 2rpx solid #ff4757;
  border-radius: 50rpx;
  font-size: 30rpx;
  padding: 30rpx 0;
}
