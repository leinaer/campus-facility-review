/* pages/admin/banner-manage.wxss */
page {
  background-color: #f5f5f5;
}

.banner-manage-container {
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

/* ==================== 顶部操作栏 ==================== */
.action-bar {
  margin-bottom: 30rpx;
}

.add-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.add-btn::after {
  border: none;
}

.add-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 30rpx;
}

/* ==================== Banner列表 ==================== */
.banner-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.banner-item {
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.banner-preview {
  position: relative;
  width: 100%;
  height: 360rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.status-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: white;
  backdrop-filter: blur(10rpx);
}

.status-badge.active {
  background: rgba(82, 196, 26, 0.9);
}

.status-badge.inactive {
  background: rgba(153, 153, 153, 0.9);
}

.banner-info {
  padding: 24rpx 30rpx;
}

.banner-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.banner-meta {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #999;
}

.meta-item {
  display: flex;
  align-items: center;
}

.banner-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 30rpx 24rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  border: none;
  border-radius: 36rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}

.toggle-btn {
  background: #f0f0f0;
  color: #666;
}

.toggle-btn.online {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: white;
}

.toggle-btn.offline {
  background: linear-gradient(135deg, #faad14 0%, #ffc53d 100%);
  color: white;
}

.edit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.delete-btn {
  background: #fff1f0;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  margin-bottom: 12rpx;
  color: #666;
}

.empty-tip {
  font-size: 26rpx;
}

/* ==================== 加载中 ==================== */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ==================== 对话框 ==================== */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.dialog-content {
  width: 100%;
  max-height: 85vh;
  background: white;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.dialog-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.dialog-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.dialog-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

/* ==================== 表单 ==================== */
.form-item {
  margin-bottom: 30rpx;
}

.form-item.required .form-label::before {
  content: '* ';
  color: #ff4d4f;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.form-input:focus {
  background: white;
  border-color: #667eea;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 图片预览 */
.image-preview {
  margin-top: 16rpx;
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.preview-img {
  width: 100%;
  height: 100%;
}

/* 单选框组 */
.radio-group {
  display: flex;
  gap: 24rpx;
}

.radio-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
}

.radio-item.checked {
  background: #f0f5ff;
  border-color: #667eea;
  color: #667eea;
}

.radio-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  position: relative;
}

.radio-item.checked .radio-icon {
  border-color: #667eea;
}

.radio-item.checked .radio-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #667eea;
}

/* 示例图片 */
.example-images {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.example-img {
  flex: 1;
  height: 160rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
}

.example-img:active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* ==================== 对话框底部按钮 ==================== */
.dialog-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 30rpx;
  border-top: 2rpx solid #f0f0f0;
  background: white;
}

.cancel-btn,
.submit-btn {
  flex: 1;
  height: 88rpx;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn::after,
.submit-btn::after {
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.cancel-btn:active,
.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
