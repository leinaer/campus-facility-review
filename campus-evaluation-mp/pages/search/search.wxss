/* pages/search/search.wxss */
page {
  background-color: #f8f9fa;
}

.container {
  min-height: 100vh;
  padding: 20rpx 30rpx;
}

/* --- 搜索栏 --- */
.search-bar {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.search-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.search-btn:active {
  opacity: 0.8;
}

/* --- 推荐区域（历史和热门） --- */
.suggest-section {
  margin-top: 20rpx;
}

.history-section, .hot-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.clear-btn {
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

.clear-btn:active {
  color: #667eea;
}

.keyword-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.keyword-tag {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: #ffffff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #333;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}

.keyword-tag text {
  margin-right: 8rpx;
}

.delete-icon {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
  padding: 4rpx;
}

.delete-icon:active {
  color: #ff4757;
}

.hot-tag {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  color: #667eea;
  font-weight: 500;
}

.keyword-tag:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* --- 搜索结果区域 --- */
.result-section {
  margin-top: 20rpx;
}

.result-header {
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.result-count {
  font-size: 26rpx;
  color: #999;
}

/* --- 设施列表 --- */
.facility-list {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.03);
}

.facility-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.facility-item:last-child {
  border-bottom: none;
}

.facility-item:active {
  background-color: #f8f9fa;
}

.facility-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  background-color: #f0f0f0;
  flex-shrink: 0;
}

.facility-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.facility-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.facility-location {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.facility-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.facility-rating {
  font-size: 26rpx;
  color: #ffb400;
  font-weight: bold;
}

.facility-campus {
  font-size: 24rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.facility-count {
  font-size: 24rpx;
  color: #999;
}

/* --- 加载更多 --- */
.load-more {
  text-align: center;
  padding: 30rpx 0;
  color: #667eea;
  font-size: 28rpx;
}

.load-more:active {
  opacity: 0.7;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
}

/* --- 加载中 --- */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #667eea;
}
