/* pages/my-collects/my-collects.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* Tab栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab-item.active {
  color: #667eea;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 2rpx;
}

.tab-badge {
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
}

/* 内容区域 */
.content-area {
  padding: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  border: none;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 帖子列表 */
.post-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.post-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.post-content {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.post-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.post-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.post-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.post-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.post-author {
  font-size: 24rpx;
  color: #999;
}

.post-stats {
  font-size: 22rpx;
  color: #999;
}

.post-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.post-tag {
  font-size: 22rpx;
  color: #667eea;
  background: #f0f3ff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.post-actions {
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: none;
}

.action-btn.cancel {
  background: #fff1f0;
  color: #ff4d4f;
}

/* 设施列表 */
.facility-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.facility-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.facility-cover {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.facility-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.facility-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.facility-location {
  font-size: 24rpx;
  color: #666;
}

.facility-stats {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.facility-rating {
  font-size: 24rpx;
  color: #ff9800;
}

.facility-reviews {
  font-size: 24rpx;
  color: #999;
}

.facility-actions {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
}
