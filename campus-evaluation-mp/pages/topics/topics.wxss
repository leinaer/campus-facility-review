.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  gap: 15rpx;
}

.search-input-box {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 15rpx 25rpx;
  background-color: #f5f5f5;
  border-radius: 50rpx;
  gap: 10rpx;
}

.search-icon {
  font-size: 32rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.clear-btn {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.search-btn {
  padding: 15rpx 30rpx;
  background-color: #1976d2;
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  border: none;
}

.search-btn::after {
  border: none;
}

.filter-bar {
  display: flex;
  background-color: #fff;
  padding: 20rpx 30rpx;
  gap: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-item {
  padding: 12rpx 30rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-item.active {
  background-color: #1976d2;
  color: #fff;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.topic-list {
  padding: 20rpx 30rpx;
}

.topic-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.topic-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.topic-icon {
  font-size: 70rpx;
  margin-right: 20rpx;
}

.topic-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.topic-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.topic-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
  line-height: 1.5;
}

.topic-stats {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.stat {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  font-size: 24rpx;
  color: #ccc;
}

.follow-btn {
  width: 100%;
  padding: 18rpx 0;
  background-color: #1976d2;
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  border: none;
}

.follow-btn::after {
  border: none;
}

.follow-btn.followed {
  background-color: #f5f5f5;
  color: #666;
}
