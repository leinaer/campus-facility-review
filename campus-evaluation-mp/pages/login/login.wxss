/* pages/login/login.wxss */
page {
  background: #0f0f23;
  overflow: hidden;
}

.login-container {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
  overflow: hidden;
}

/* ==================== 动态渐变背景 ==================== */
.gradient-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  z-index: 0;
  animation: gradientShift 15s ease infinite;
  background-size: 400% 400%;
}

@keyframes gradientShift {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.6;
  animation: float 20s ease-in-out infinite;
}

.orb-1 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 70%);
  top: -200rpx;
  right: -200rpx;
  animation-delay: 0s;
}

.orb-2 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.25) 0%, transparent 70%);
  bottom: -150rpx;
  left: -150rpx;
  animation-delay: -5s;
}

.orb-3 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
  top: 40%;
  left: 30%;
  animation-delay: -10s;
}

@keyframes float {
  0%, 100% {
    transform: translate(0, 0) scale(1);
  }
  33% {
    transform: translate(30rpx, -30rpx) scale(1.1);
  }
  66% {
    transform: translate(-20rpx, 20rpx) scale(0.9);
  }
}

/* 网格装饰 */
.grid-pattern {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1rpx, transparent 1rpx);
  background-size: 60rpx 60rpx;
  z-index: 1;
  pointer-events: none;
}

/* ==================== 主内容区 ==================== */
.login-content {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 680rpx;
  margin-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ==================== Logo 区域 ==================== */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 48rpx;
}

.logo {
  width: 100%;
  height: 100%;
  border-radius: 48rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  animation: logoFloat 6s ease-in-out infinite;
}

@keyframes logoFloat {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.logo-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 70%);
  border-radius: 50%;
  z-index: 1;
  animation: glowPulse 3s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% {
    opacity: 0.5;
    transform: translate(-50%, -50%) scale(1);
  }
  50% {
    opacity: 0.8;
    transform: translate(-50%, -50%) scale(1.1);
  }
}

.app-name {
  font-size: 52rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 装饰线条 */
.divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 40rpx;
}

.divider-line {
  width: 120rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
}

.divider-text {
  font-size: 24rpx;
}

/* ==================== 功能介绍卡片 ==================== */
.features-card {
  display: flex;
  justify-content: space-around;
  width: 100%;
  padding: 32rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  margin-bottom: 60rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.feature-icon {
  font-size: 48rpx;
  animation: iconBounce 2s ease-in-out infinite;
}

.feature-item:nth-child(2) .feature-icon {
  animation-delay: 0.3s;
}

.feature-item:nth-child(3) .feature-icon {
  animation-delay: 0.6s;
}

@keyframes iconBounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-6rpx);
  }
}

.feature-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

/* ==================== 登录按钮区域 ==================== */
.login-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 100%;
  height: 108rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #667eea;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 54rpx;
  border: none;
  position: relative;
  overflow: hidden;
  box-shadow:
    0 10rpx 40rpx rgba(0, 0, 0, 0.2),
    0 0 0 1rpx rgba(255, 255, 255, 0.1);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
}

.login-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
  transition: left 0.5s;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.15);
}

.login-btn:active::before {
  left: 100%;
}

.login-btn.loading {
  background: rgba(255, 255, 255, 0.7);
  color: #999;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  position: relative;
  z-index: 2;
}

.btn-icon {
  font-size: 40rpx;
  animation: wave 2s ease-in-out infinite;
}

@keyframes wave {
  0%, 100% {
    transform: rotate(0deg);
  }
  25% {
    transform: rotate(20deg);
  }
  75% {
    transform: rotate(-15deg);
  }
}

.btn-text {
  letter-spacing: 1rpx;
}

.btn-shimmer {
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  animation: shimmer 3s infinite;
}

@keyframes shimmer {
  0% {
    left: -100%;
  }
  100% {
    left: 100%;
  }
}

.login-tip-wrapper {
  margin-top: 32rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 6rpx;
}

.login-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.link-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
  text-decoration: underline;
  text-decoration-color: rgba(255, 255, 255, 0.5);
  text-underline-offset: 4rpx;
}

/* ==================== 底部 ==================== */
.footer {
  position: fixed;
  bottom: 60rpx;
  left: 0;
  right: 0;
  text-align: center;
  z-index: 2;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 1rpx;
}
