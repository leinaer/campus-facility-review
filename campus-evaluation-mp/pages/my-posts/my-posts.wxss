.container {
  min-height: 100vh;
  background-color: #f5f6f8;
  padding-bottom: 20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.go-publish-btn {
  padding: 20rpx 60rpx;
  background-color: #ff2442;
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  border: none;
}

.go-publish-btn::after {
  border: none;
}

/* --- 瀑布流布局 --- */
.waterfall-container {
  display: flex;
  gap: 16rpx;
  padding: 0 20rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.note-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.note-cover {
  width: 100%;
  position: relative;
}

.cover-image {
  width: 100%;
  height: 360rpx;
  display: block;
  background-color: #f5f6f8;
}

.note-content {
  padding: 20rpx;
}

.note-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.note-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.note-stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  font-size: 22rpx;
  color: #999999;
}

.note-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 8rpx 16rpx;
}

.loading-state {
  text-align: center;
  padding: 40rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #999999;
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 24rpx;
}
