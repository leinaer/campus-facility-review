<!--pages/category/category.wxml-->
<view class="category-container">
  <!-- 页面标题和操作栏 -->
  <view class="header-bar">
    <text class="page-title">分类管理</text>
    <view class="add-btn" bindtap="showAddDialog">
      <text class="add-icon">+</text>
      <text class="add-text">添加分类</text>
    </view>
  </view>

  <!-- 分类列表 -->
  <view class="category-list">
    <view wx:if="{{categories.length === 0}}" class="empty-state">
      <text class="empty-icon"></text>
      <text class="empty-text">暂无分类数据</text>
    </view>

    <block wx:for="{{categories}}" wx:key="categoryId">
      <view class="category-item">
        <!-- 左侧图标 -->
        <view class="item-icon-wrapper" style="background: {{item.color || '#667eea'}}">
          <text class="item-icon">{{item.displayIcon || ''}}</text>
        </view>
        
        <!-- 中间信息 -->
        <view class="item-content">
          <text class="item-name">{{item.name}}</text>
          <view class="item-footer">
            <text class="sort-tag">排序: {{item.sortOrder || 0}}</text>
            <view class="status-badge {{item.status === 1 ? 'active' : 'inactive'}}">
              <text>{{item.status === 1 ? '已启用' : '已禁用'}}</text>
            </view>
            <text class="category-id">ID: {{item.categoryId}}</text>
          </view>
        </view>

        <!-- 右侧操作 -->
        <view class="item-actions">
          <view class="action-btn edit-btn" bindtap="showEditDialog" data-item="{{item}}">
            <text>编辑</text>
          </view>
          <view class="action-btn delete-btn" bindtap="deleteCategory" data-item="{{item}}">
            <text>删除</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 添加/编辑对话框 -->
  <view wx:if="{{showDialog}}" class="dialog-mask" bindtap="hideDialog">
    <view class="dialog-content" catchtap="stopPropagation">
      <view class="dialog-header">
        <text class="dialog-title">{{isEdit ? '编辑分类' : '添加分类'}}</text>
        <view class="dialog-close" bindtap="hideDialog">
          <text class="close-icon">×</text>
        </view>
      </view>

      <scroll-view class="dialog-body" scroll-y>
        <view class="form-item">
          <text class="form-label">分类名称</text>
          <input class="form-input" placeholder="请输入分类名称" value="{{form.name}}" bindinput="onNameInput" />
        </view>

        <view class="form-item">
          <text class="form-label">选择图标</text>
          <view class="icon-grid">
            <view 
              wx:for="{{iconOptions}}"
              wx:key="index"
              class="icon-option {{form.iconUrl === item.name ? 'active' : ''}}"
              bindtap="selectIcon"
              data-icon="{{item.name}}"
            >
              <text class="option-icon">{{item.name}}</text>
              <text class="option-label">{{item.label}}</text>
            </view>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">排序号</text>
          <input class="form-input" type="number" placeholder="数字越小越靠前" value="{{form.sortOrder}}" bindinput="onSortOrderInput" />
        </view>

        <view class="form-item">
          <text class="form-label">状态</text>
          <radio-group bindchange="onStatusChange">
            <label class="radio-label">
              <radio value="1" checked="{{form.status === 1}}" />启用
            </label>
            <label class="radio-label">
              <radio value="0" checked="{{form.status === 0}}" />禁用
            </label>
          </radio-group>
        </view>
      </scroll-view>

      <view class="dialog-footer">
        <button class="btn-cancel" bindtap="hideDialog">取消</button>
        <button class="btn-confirm" bindtap="submitForm">确定</button>
      </view>
    </view>
  </view>
</view>
