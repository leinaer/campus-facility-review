.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.content-area {
  padding-bottom: 20rpx;
}

.topic-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.topic-info {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.topic-icon {
  font-size: 80rpx;
  margin-right: 20rpx;
}

.topic-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.topic-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 10rpx;
}

.topic-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 15rpx;
  line-height: 1.5;
}

.topic-stats {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.stat-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.stat-divider {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.follow-btn {
  width: 100%;
  padding: 20rpx 0;
  background-color: rgba(255, 255, 255, 0.3);
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.follow-btn::after {
  border: none;
}

.follow-btn.followed {
  background-color: rgba(255, 255, 255, 0.2);
  border-color: rgba(255, 255, 255, 0.3);
}

.posts-section {
  padding: 0 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding: 20rpx 10rpx;
}

.empty-posts {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.post-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 5rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.post-body {
  margin-bottom: 20rpx;
}

.content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.post-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.post-image {
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.tag {
  padding: 8rpx 20rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.post-footer {
  display: flex;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-item .icon {
  font-size: 32rpx;
}

.stat-item .count {
  font-size: 24rpx;
  color: #666;
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}
