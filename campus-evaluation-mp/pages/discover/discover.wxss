.discover-container {
  background-color: #f5f6f8;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  gap: 20rpx;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f5f6f8;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  gap: 12rpx;
}

.search-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.search-placeholder {
  color: #999999;
  font-size: 26rpx;
}

.filter-bar {
  display: flex;
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  gap: 40rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666666;
  background-color: transparent;
  transition: all 0.3s;
  position: relative;
}

.filter-item.active {
  color: #ff2442;
  font-weight: bold;
}

.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #ff2442;
  border-radius: 2rpx;
}

/* --- 瀑布流布局 --- */
.waterfall-container {
  display: flex;
  gap: 16rpx;
  padding: 0 20rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.note-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.note-cover {
  width: 100%;
  position: relative;
}

.cover-image {
  width: 100%;
  height: 360rpx;
  display: block;
  background-color: #f5f6f8;
}


.note-content {
  padding: 20rpx;
}

.note-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.note-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.note-author {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.author-name {
  font-size: 22rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 12rpx;
  flex-shrink: 0;
}

.like-icon-img {
  width: 28rpx;
  height: 28rpx;
}

.like-count {
  font-size: 22rpx;
  color: #999999;
}

.like-count.liked {
  color: #ff2442;
}

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.loading-state {
  text-align: center;
  padding: 40rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #999999;
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 24rpx;
}
