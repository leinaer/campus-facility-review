.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 30rpx;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  min-height: 100rpx;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.value-row {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.arrow {
  font-size: 48rpx;
  color: #ccc;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.textarea {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  min-height: 120rpx;
  padding-top: 8rpx;
}

.radio-group {
  flex: 1;
  display: flex;
  gap: 40rpx;
  justify-content: flex-end;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.btn-group {
  margin-top: 40rpx;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.btn-save::after {
  border: none;
}
