<view class="container">
  <view class="form-section">
    <view class="form-item" bindtap="chooseAvatar">
      <text class="label">头像</text>
      <view class="value-row">
        <image class="avatar-preview" src="{{form.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" lazy-load />
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" placeholder="请输入昵称" value="{{form.nickname}}" maxlength="20" bindinput="onNicknameInput" />
    </view>

    <view class="form-item">
      <text class="label">个性签名</text>
      <textarea class="textarea" placeholder="写点什么介绍一下自己吧~" value="{{form.signature}}" maxlength="100" bindinput="onSignatureInput" />
    </view>

    <view class="form-item">
      <text class="label">性别</text>
      <radio-group bindchange="onGenderChange" class="radio-group">
        <label class="radio-item">
          <radio value="0" checked="{{form.gender === 0}}" />未知
        </label>
        <label class="radio-item">
          <radio value="1" checked="{{form.gender === 1}}" />男
        </label>
        <label class="radio-item">
          <radio value="2" checked="{{form.gender === 2}}" />女
        </label>
      </radio-group>
    </view>
  </view>

  <view class="btn-group">
    <button class="btn-save" bindtap="saveProfile" loading="{{saving}}">保存</button>
  </view>
</view>
